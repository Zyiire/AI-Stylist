# Copy this file to .env and fill in your values.


# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=AI-Fashion

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── CLIP model ────────────────────────────────────────────────────────────────
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai
EMBEDDING_DIM=512

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: leave as "*"
# Production: set to your Vercel deployment URL (no trailing slash)
ALLOWED_ORIGINS=*

# ── Pexels (free at pexels.com/api) ──────────────────────────────────────────
PEXELS_API_KEY=your-pexels-api-key

# ── Pinterest (optional — for ingest_pinterest.py) ────────────────────────────
PINTEREST_ACCESS_TOKEN=your-pinterest-token
PINTEREST_APP_ID=your-app-id
PINTEREST_APP_SECRET=your-app-secret

# ── eBay (optional — for ingest_ebay.py) ─────────────────────────────────────
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id

# ── Frontend (set in frontend/.env.local) ─────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://your-railway-app.up.railway.app
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
